# syntax=docker/dockerfile:1

# TODO: pin to digest for reproducibility (e.g., golang:1.26.0-bookworm@sha256:...)
FROM golang:1.26.0-bookworm

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates git gcc \
    && rm -rf /var/lib/apt/lists/*

COPY go.mod go.sum ./
RUN go mod download

COPY . .

CMD ["go", "test", "./..."]
